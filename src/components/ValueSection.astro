---
import { getCollection } from 'astro:content';
import Icon from './Icon.astro';

const valueProps = (await getCollection('value-props')).sort((a, b) => a.data.order - b.data.order);
---

<section id="value" class="relative z-10 bg-cream max-w-screen-xl mx-auto px-6 pt-20 pb-16">
  <div class="text-center mb-12">
    <div class="section-label">SUPERIOR SEO + BRAND POWER</div>
    <h2 class="text-4xl md:text-5xl tracking-tighter font-semibold mt-3">
      Why SugarWaxBrazilian.com is exceptionally valuable
    </h2>
    <p class="mt-4 max-w-md mx-auto text-gray-600">
      Exact-match, keyword-rich domains of this quality in high-intent beauty categories are exceptionally scarce.
    </p>
  </div>

  <div class="grid md:grid-cols-3 gap-6">
    {
      valueProps.map(({ data }) => (
        <div class="value-card bg-white border border-border rounded-3xl p-8">
          <div class="w-12 h-12 bg-cream rounded-2xl flex items-center justify-center mb-6">
            <Icon name={data.icon} class="w-7 h-7 text-rose" />
          </div>
          <h3 class="text-2xl font-semibold tracking-tight">{data.title}</h3>
          <p class="mt-4 text-gray-600">{data.description}</p>
          <div class="mt-6 pt-6 border-t border-border text-sm text-gray-500">
            <span class="font-medium text-rose">Advantage:</span> {data.advantage}
          </div>
        </div>
      ))
    }
  </div>
</section>

<div class="border-b border-border bg-white py-6">
  <div class="max-w-screen-xl mx-auto px-6">
    <div class="flex flex-wrap justify-center md:justify-between items-center gap-x-10 gap-y-4 text-sm">
      <div class="text-gray-500 font-medium">Built for specialists in natural Brazilian hair removal</div>
      <div class="flex flex-wrap gap-x-8 text-xs tracking-[1.5px] font-semibold text-gray-600">
        <div>SUGAR WAX SALONS</div>
        <div>MOBILE SERVICES</div>
        <div>TRAINING ACADEMIES</div>
        <div>PRODUCT BRANDS</div>
      </div>
    </div>
  </div>
</div>
