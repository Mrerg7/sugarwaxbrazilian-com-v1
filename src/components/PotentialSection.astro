---
import { getCollection } from 'astro:content';
import Icon from './Icon.astro';

const personas = (await getCollection('buyer-personas')).sort((a, b) => a.data.order - b.data.order);
---

<section id="potential" class="max-w-screen-xl mx-auto px-6 pt-20 pb-16">
  <div class="text-center mb-12">
    <div class="section-label">HIGHLY VERSATILE BRAND</div>
    <h2 class="text-4xl md:text-5xl tracking-tighter font-semibold mt-3">
      Perfect foundation for a specialized Brazilian sugaring business
    </h2>
  </div>

  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
    {
      personas.map(({ data }) => (
        <div class="bg-white border border-border rounded-3xl p-7 value-card">
          <div class="text-rose mb-4">
            <Icon name={data.icon} class="w-7 h-7" />
          </div>
          <h3 class="font-semibold text-xl tracking-tight">{data.title}</h3>
          <p class="mt-3 text-sm text-gray-600">{data.description}</p>
          <div class="mt-5 text-xs font-medium text-rose">{data.highlight}</div>
        </div>
      ))
    }
  </div>

  <p class="mt-10 text-center text-sm text-gray-500 max-w-lg mx-auto">
    Whether you're launching a boutique sugar wax studio or scaling a national natural beauty brand — this domain gives
    you an unfair advantage from day one.
  </p>
</section>
