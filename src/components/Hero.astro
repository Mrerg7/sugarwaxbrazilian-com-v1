---
import { ACQUISITION_MAILTO, cfImageUrl, CF_IMAGES, SITE } from '../config/site';
import Icon from './Icon.astro';

const heroImage = cfImageUrl(CF_IMAGES.heroImageId);
---

<header class="relative isolate h-screen flex items-center justify-center overflow-hidden border-b border-border">
  <img
    src={heroImage}
    alt=""
    width="1920"
    height="1080"
    fetchpriority="high"
    decoding="async"
    class="absolute inset-0 z-0 h-full w-full object-cover"
  />
  <div class="absolute inset-0 z-[1] bg-gradient-to-b from-black/40 via-black/25 to-cream/95" aria-hidden="true"></div>

  <div class="relative z-[2] max-w-screen-xl mx-auto px-6 py-20 text-center">
    <div class="max-w-4xl mx-auto">
      <div class="inline-flex items-center gap-x-2 bg-white/95 px-5 py-2 rounded-3xl shadow-sm border border-border mb-8">
        <Icon name="globe" class="w-4 h-4 text-rose" />
        <span class="text-sm font-semibold tracking-wider text-gray-700">PREMIUM EXACT-MATCH .COM</span>
      </div>

      <h1
        id="domain-title"
        class="text-[2rem] leading-tight sm:text-5xl md:text-6xl lg:text-7xl tracking-[-1.5px] sm:tracking-[-2.5px] font-semibold text-white drop-shadow-sm cursor-pointer break-words"
        title="Click to copy domain to clipboard"
      >
        {SITE.name}
      </h1>
      <p class="mt-4 text-xl sm:text-2xl md:text-3xl tracking-tight text-rose-light font-medium">
        Now available for acquisition
      </p>

      <p class="mt-6 max-w-2xl mx-auto text-base sm:text-xl text-white/90">
        The definitive, brandable domain for natural sugaring and gentle Brazilian wax services.
        A rare strategic asset in one of beauty's fastest-growing categories.
      </p>

      <div class="mt-9 flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={ACQUISITION_MAILTO}
          class="btn-primary px-10 py-4 text-lg font-semibold rounded-3xl flex items-center justify-center gap-x-3 shadow-lg shadow-rose-dark/20"
        >
          <span>Inquire About Acquisition</span>
          <Icon name="arrow-right" class="w-5 h-5" />
        </a>

        <a
          href="#value"
          class="px-10 py-4 text-lg font-semibold border border-white/40 hover:bg-white/10 text-white rounded-3xl flex items-center justify-center gap-x-3 transition-colors"
        >
          <span>Explore Domain Value</span>
        </a>
      </div>

      <div class="mt-8 flex flex-wrap justify-center gap-x-8 gap-y-2 text-sm text-white/80">
        <div class="flex items-center gap-x-2">
          <Icon name="check" class="w-4 h-4 text-emerald-400" />
          <span>Exact-match keywords</span>
        </div>
        <div class="flex items-center gap-x-2">
          <Icon name="check" class="w-4 h-4 text-emerald-400" />
          <span>Premium .com</span>
        </div>
        <div class="flex items-center gap-x-2">
          <Icon name="check" class="w-4 h-4 text-emerald-400" />
          <span>Instant brand recognition</span>
        </div>
      </div>

      <div class="mt-12 animate-bounce">
        <a href="#value" class="inline-flex flex-col items-center gap-y-2 text-white/60 hover:text-white transition-colors">
          <span class="text-xs uppercase tracking-[3px] font-semibold">Scroll</span>
          <Icon name="chevron-down" class="w-4 h-4" />
        </a>
      </div>
    </div>
  </div>
</header>

<script define:vars={{ domain: SITE.domain, displayName: SITE.name }}>
  const domainTitle = document.getElementById('domain-title');
  domainTitle?.addEventListener('click', () => {
    navigator.clipboard.writeText(domain).then(() => {
      const orig = domainTitle.innerHTML;
      domainTitle.innerHTML = `${displayName} <span class="text-sm align-super">✓ Copied</span>`;
      setTimeout(() => {
        domainTitle.innerHTML = orig;
      }, 1400);
    });
  });
</script>
