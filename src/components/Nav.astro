---
import { ACQUISITION_MAILTO, SITE } from '../config/site';
---

<nav id="navbar" class="bg-white border-b border-border sticky top-0 z-50 transition-all duration-300">
  <div class="max-w-screen-xl mx-auto">
    <div class="px-6 py-5 flex items-center justify-between">
      <a href="/" class="flex items-center gap-x-3">
        <div class="w-10 h-10 bg-rose rounded-2xl flex items-center justify-center shadow-inner">
          <span class="text-white text-2xl font-bold tracking-tighter">SB</span>
        </div>
        <div>
          <div class="font-semibold text-2xl tracking-tighter">
            {SITE.name}
          </div>
          <div class="text-[10px] text-gray-500 -mt-1 tracking-[2px]">PREMIUM DOMAIN</div>
        </div>
      </a>

      <div class="hidden md:flex items-center gap-x-8 text-sm font-medium">
        <a href="#value" class="nav-link text-gray-700">Domain Value</a>
        <a href="#sugaring" class="nav-link text-gray-700">The Sugaring Opportunity</a>
        <a href="#potential" class="nav-link text-gray-700">Unlimited Potential</a>
        <a href="#acquire" class="nav-link text-gray-700">Inquire</a>
      </div>

      <div class="flex items-center gap-x-3">
        <a
          href="#acquire"
          class="hidden sm:inline-flex items-center px-6 py-2.5 text-sm font-semibold text-rose hover:bg-cream rounded-3xl transition-colors border border-border"
        >
          Make an Offer
        </a>
        <a
          href={ACQUISITION_MAILTO}
          class="btn-primary text-white px-7 py-2.5 text-sm font-semibold rounded-3xl shadow-sm flex items-center gap-x-2"
        >
          <span>Inquire Now</span>
        </a>

        <button
          id="mobile-menu-btn"
          class="md:hidden w-10 h-10 flex items-center justify-center text-gray-600 hover:text-rose"
          aria-label="Toggle menu"
        >
          <i class="fa-solid fa-bars text-xl"></i>
        </button>
      </div>
    </div>
  </div>

  <div id="mobile-menu" class="hidden md:hidden border-t bg-white px-6 py-4">
    <div class="flex flex-col gap-y-4 text-sm font-medium">
      <a href="#value" class="py-1 text-gray-700">Domain Value</a>
      <a href="#sugaring" class="py-1 text-gray-700">The Sugaring Opportunity</a>
      <a href="#potential" class="py-1 text-gray-700">Unlimited Potential</a>
      <div class="pt-3 border-t">
        <a
          href={ACQUISITION_MAILTO}
          class="block w-full py-3 text-center text-sm font-semibold bg-rose text-white rounded-3xl"
        >
          Inquire About Acquisition
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  const navbar = document.getElementById('navbar');
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  window.addEventListener('scroll', () => {
    if (!navbar) return;
    if (window.scrollY > 80) {
      navbar.classList.add('nav-scrolled', 'bg-white/95', 'backdrop-blur-lg');
    } else {
      navbar.classList.remove('nav-scrolled', 'bg-white/95', 'backdrop-blur-lg');
    }
  });

  btn?.addEventListener('click', () => {
    if (!menu || !btn) return;
    const isOpen = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden', isOpen);
    btn.innerHTML = isOpen
      ? '<i class="fa-solid fa-bars text-xl"></i>'
      : '<i class="fa-solid fa-times text-xl"></i>';
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
      if (btn) btn.innerHTML = '<i class="fa-solid fa-bars text-xl"></i>';
    });
  });
</script>
