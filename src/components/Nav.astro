---
import { ACQUISITION_MAILTO, SITE } from '../config/site';
import Icon from './Icon.astro';
---

<nav id="navbar" class="bg-white border-b border-border sticky top-0 z-50 transition-all duration-300">
  <div class="max-w-screen-xl mx-auto">
    <div class="px-4 sm:px-6 py-4 sm:py-5 flex items-center justify-between gap-3">
      <a href="/" class="flex min-w-0 items-center gap-x-2 sm:gap-x-3">
        <div class="w-10 h-10 shrink-0 bg-rose-dark rounded-2xl flex items-center justify-center shadow-inner">
          <span class="text-white text-sm font-bold tracking-tighter">SWB</span>
        </div>
        <div class="min-w-0">
          <div class="font-semibold text-sm sm:text-xl md:text-2xl tracking-tighter leading-tight truncate sm:whitespace-normal">
            <span>sugarwaxbrazilian</span><span class="text-rose">.com</span>
          </div>
          <div class="hidden sm:block text-[10px] text-gray-500 -mt-1 tracking-[2px]">PREMIUM DOMAIN</div>
        </div>
      </a>

      <div class="hidden md:flex items-center gap-x-8 text-sm font-medium">
        <a href="#value" class="nav-link text-gray-700">Why This Domain</a>
        <a href="#sugaring" class="nav-link text-gray-700">About Sugar Wax Brazilian</a>
        <a href="#market" class="nav-link text-gray-700">Market &amp; Revenue</a>
        <a href="#acquire" class="nav-link text-gray-700">Inquire</a>
      </div>

      <div class="flex shrink-0 items-center gap-x-2 sm:gap-x-3">
        <a
          href="#acquire"
          class="hidden sm:inline-flex items-center px-6 py-2.5 text-sm font-semibold text-rose hover:bg-cream rounded-3xl transition-colors border border-border"
        >
          Make an Offer
        </a>
        <a
          href={ACQUISITION_MAILTO}
          class="btn-primary px-4 sm:px-7 py-2.5 min-h-11 min-w-11 text-sm font-semibold rounded-3xl shadow-sm inline-flex items-center justify-center gap-x-2"
          aria-label="Inquire about domain acquisition"
        >
          <span class="hidden sm:inline">Inquire Now</span>
          <Icon name="envelope" class="w-4 h-4 sm:hidden" />
        </a>

        <button
          id="mobile-menu-btn"
          class="md:hidden w-11 h-11 flex items-center justify-center text-gray-600 hover:text-rose"
          aria-label="Toggle menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <Icon name="bars" class="w-5 h-5 menu-icon-open" />
          <Icon name="times" class="w-5 h-5 menu-icon-close hidden" />
        </button>
      </div>
    </div>
  </div>

  <div id="mobile-menu" class="hidden md:hidden border-t bg-white px-6 py-4">
    <div class="flex flex-col gap-y-4 text-sm font-medium">
      <a href="#value" class="py-1 text-gray-700">Why This Domain</a>
      <a href="#sugaring" class="py-1 text-gray-700">About Sugar Wax Brazilian</a>
      <a href="#market" class="py-1 text-gray-700">Market &amp; Revenue</a>
      <a href="#potential" class="py-1 text-gray-700">Use Cases</a>
      <div class="pt-3 border-t">
        <a
          href={ACQUISITION_MAILTO}
          class="block w-full py-3 text-center text-sm font-semibold bg-rose-dark text-white rounded-3xl"
        >
          Inquire to Acquire
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  const navbar = document.getElementById('navbar');
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = btn?.querySelector('.menu-icon-open');
  const iconClose = btn?.querySelector('.menu-icon-close');

  window.addEventListener('scroll', () => {
    if (!navbar) return;
    if (window.scrollY > 80) {
      navbar.classList.add('nav-scrolled', 'bg-white/95', 'backdrop-blur-lg');
    } else {
      navbar.classList.remove('nav-scrolled', 'bg-white/95', 'backdrop-blur-lg');
    }
  });

  btn?.addEventListener('click', () => {
    if (!menu || !btn) return;
    const isOpen = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden', isOpen);
    btn.setAttribute('aria-expanded', String(!isOpen));
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
      btn?.setAttribute('aria-expanded', 'false');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
    });
  });
</script>
