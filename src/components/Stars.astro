---
interface Props {
  rating: number;
  class?: string;
}

const { rating, class: className = 'text-rose w-4 h-4' } = Astro.props;

function stars(rating: number): Array<'star' | 'star-half' | 'star-outline'> {
  const result: Array<'star' | 'star-half' | 'star-outline'> = [];
  for (let i = 1; i <= 5; i++) {
    if (rating >= i) result.push('star');
    else if (rating >= i - 0.5) result.push('star-half');
    else result.push('star-outline');
  }
  return result;
}
---

<div class="flex gap-x-1">
  {
    stars(rating).map((name, index) => (
      <svg class={className} viewBox="0 0 24 24" aria-hidden="true">
        {name === 'star' && (
          <path fill="currentColor" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
        )}
        {name === 'star-outline' && (
          <path fill="none" stroke="currentColor" stroke-width="1.5" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
        )}
        {name === 'star-half' && (
          <>
            <defs>
              <clipPath id={`star-half-${index}`}>
                <rect x="0" y="0" width="12" height="24" />
              </clipPath>
            </defs>
            <path fill="currentColor" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" clip-path={`url(#star-half-${index})`} />
            <path fill="none" stroke="currentColor" stroke-width="1.5" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
          </>
        )}
      </svg>
    ))
  }
</div>
