---
import { ACQUISITION_MAILTO, SITE } from '../config/site';
import Icon from './Icon.astro';
---

<section id="acquire" class="max-w-screen-xl mx-auto px-6 py-20">
  <div class="max-w-3xl mx-auto">
    <div class="text-center mb-10">
      <div class="section-label">SEO-SUPERIOR PREMIUM DOMAIN</div>
      <h2 class="text-4xl md:text-5xl tracking-tighter font-semibold mt-3">
        Own the most searchable name in Brazilian sugar waxing.
      </h2>
      <p class="mt-4 text-gray-600 max-w-md mx-auto">
        {SITE.domain} is a high-value, keyword-rich asset. Serious inquiries only — we respond promptly to qualified
        buyers.
      </p>
    </div>

    <div class="bg-white border border-border rounded-3xl p-9 md:p-12 text-center">
      <div class="mx-auto w-14 h-14 bg-cream rounded-2xl flex items-center justify-center mb-6">
        <Icon name="handshake" class="w-8 h-8 text-rose" />
      </div>

      <p class="text-gray-600 mb-8">
        To inquire about acquiring <strong>{SITE.domain}</strong>, contact us directly. All inquiries are handled with
        strict confidentiality.
      </p>

      <a
        href={ACQUISITION_MAILTO}
        class="inline-flex items-center justify-center gap-x-3 w-full sm:w-auto px-10 py-4 btn-primary font-semibold text-lg rounded-3xl shadow-sm"
      >
        <span>Make an Offer</span>
        <Icon name="envelope" class="w-5 h-5" />
      </a>

      <p class="mt-6 text-sm text-gray-500">
        Or email directly:
        <a href={`mailto:${SITE.email}`} class="text-rose hover:underline font-medium">{SITE.email}</a>
      </p>

      <p class="text-center text-xs text-gray-500 mt-4">
        Your information is confidential. We only respond to serious, qualified buyers.
      </p>
    </div>
  </div>
</section>

<div class="bg-rose-dark py-14 text-white">
  <div class="max-w-screen-xl mx-auto px-6 text-center">
    <h3 class="text-3xl md:text-4xl tracking-tighter font-semibold">
      The window to own {SITE.domain} is open — but it won't stay that way.
    </h3>
    <p class="mt-3 max-w-md mx-auto text-white/90">
      Premium keyword-rich domains in growing beauty categories are acquired quickly by those who recognize their
      long-term value.
    </p>

    <a
      href={ACQUISITION_MAILTO}
      class="mt-8 inline-flex items-center gap-x-3 px-10 py-4 bg-white text-rose-dark font-semibold rounded-3xl text-base hover:bg-gray-100 transition-colors"
    >
      Start the Conversation
      <Icon name="arrow-right" class="w-5 h-5" />
    </a>
  </div>
</div>
