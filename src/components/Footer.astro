---
import { ACQUISITION_MAILTO, DISCLAIMER, SITE } from '../config/site';
---

<footer class="bg-white border-t border-border">
  <div class="max-w-screen-xl mx-auto px-6 py-16">
    <!-- Sophisticated Domain Acquisition CTA -->
    <div class="relative overflow-hidden rounded-3xl border border-rose/25 bg-gradient-to-br from-gray-900 via-gray-950 to-rose/10 p-8 sm:p-12 mb-12">
      <div
        class="absolute -top-24 -right-24 w-64 h-64 rounded-full bg-rose/10 blur-3xl pointer-events-none"
        aria-hidden="true"
      ></div>
      <div
        class="absolute -bottom-24 -left-24 w-64 h-64 rounded-full bg-rose-light/10 blur-3xl pointer-events-none"
        aria-hidden="true"
      ></div>

      <div class="relative z-10 grid lg:grid-cols-[1.2fr_0.8fr] gap-10 items-center">
        <div>
          <p class="text-xs uppercase tracking-[3px] text-rose-light font-extrabold mb-4">
            Domain Available for Acquisition
          </p>
          <h2 class="font-display text-3xl sm:text-4xl tracking-tight text-white mb-4">
            {SITE.name} — A Category-Defining Digital Asset
          </h2>
          <p class="text-gray-400 max-w-xl leading-relaxed">
            Positioned at the intersection of natural sugaring, Brazilian wax services, and premium beauty branding,
            this exact-match .com is a rare strategic asset. Serious buyers may inquire for pricing, transfer logistics,
            and escrow options.
          </p>
        </div>

        <div
          class="rounded-2xl p-6 sm:p-8 border border-white/10"
          style="background: rgba(10, 10, 10, 0.88); backdrop-filter: blur(22px);"
        >
          <p class="text-xs uppercase tracking-[2px] text-gray-500 font-semibold mb-2">Acquisition Contact</p>
          <a
            href={`mailto:${SITE.email}`}
            class="block text-2xl sm:text-3xl font-display text-white hover:text-rose-light transition-colors break-all"
          >
            {SITE.email}
          </a>
          <a
            href={ACQUISITION_MAILTO}
            class="mt-6 inline-flex w-full items-center justify-center gap-x-3 px-6 py-4 bg-gradient-to-r from-rose to-rose-dark text-white font-extrabold rounded-2xl hover:brightness-110 transition-all"
          >
            <span>Inquire About Acquisition</span>
            <i class="fa-solid fa-arrow-right"></i>
          </a>
          <p class="mt-4 text-[11px] text-gray-500 text-center tracking-wide">
            Confidential inquiries &bull; Response within 24 hours
          </p>
        </div>
      </div>
    </div>

    <!-- Disclaimer -->
    <p class="text-xs text-gray-500 leading-relaxed max-w-4xl mb-10">
      {DISCLAIMER}
    </p>

    <!-- Bottom bar -->
    <div class="pt-8 border-t border-border text-xs text-gray-500 flex flex-col md:flex-row gap-y-4 items-center justify-between">
      <div class="flex items-center gap-x-3">
        <div class="w-9 h-9 bg-rose rounded-2xl flex items-center justify-center">
          <span class="text-white font-bold text-xl tracking-tighter">SB</span>
        </div>
        <div>
          <div class="font-semibold text-gray-700">{SITE.name}</div>
          <div>&copy; 2026 &bull; All rights reserved.</div>
        </div>
      </div>
      <div class="flex flex-wrap items-center gap-x-6 gap-y-2">
        <a href="#value" class="hover:text-rose transition-colors">Domain Value</a>
        <a href="#sugaring" class="hover:text-rose transition-colors">Sugaring Benefits</a>
        <a href="#potential" class="hover:text-rose transition-colors">Buyer Personas</a>
        <span class="text-gray-400">Premium domain listing by owner</span>
      </div>
    </div>
  </div>
</footer>
