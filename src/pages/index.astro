---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import ValueSection from '../components/ValueSection.astro';
import SugaringSection from '../components/SugaringSection.astro';
import MarketSection from '../components/MarketSection.astro';
import PotentialSection from '../components/PotentialSection.astro';
import TestimonialsSection from '../components/TestimonialsSection.astro';
import AcquisitionCTA from '../components/AcquisitionCTA.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
  <Nav />
  <main class="relative z-10 bg-cream">
    <Hero />
    <ValueSection />
    <SugaringSection />
    <MarketSection />
    <PotentialSection />
    <TestimonialsSection />
    <AcquisitionCTA />
    <Footer />
  </main>
</BaseLayout>
