---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ACQUISITION_MAILTO, SITE } from '../config/site';
---

<BaseLayout title={`Page Not Found | ${SITE.name}`} noindex>
  <main class="min-h-screen flex items-center justify-center premium-gradient px-6">
    <div class="text-center max-w-md">
      <p class="text-6xl font-semibold text-rose">404</p>
      <h1 class="mt-4 text-2xl font-semibold tracking-tight">Page not found</h1>
      <p class="mt-3 text-gray-600">
        The page you're looking for doesn't exist. Return to the domain listing or inquire about acquisition.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="px-8 py-3 bg-rose text-white font-semibold rounded-3xl hover:bg-rose-dark transition-colors">
          Back to Home
        </a>
        <a
          href={ACQUISITION_MAILTO}
          class="px-8 py-3 border border-border hover:bg-white font-semibold rounded-3xl transition-colors"
        >
          Inquire About Domain
        </a>
      </div>
    </div>
  </main>
</BaseLayout>
